generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                 @id @default(cuid())
  name                 String
  email                String                 @unique
  password             String
  color                String                 @default("#6366f1")
  createdAt            DateTime               @default(now())
  transactions         Transaction[]
  recurringTransactions RecurringTransaction[]
  pushSubscriptions    PushSubscription[]
  notificationPrefs    NotificationPrefs?
  budgetAlertsSent     BudgetAlertSent[]
}

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  @@index([userId])
}

model NotificationPrefs {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  budgetWarning   Boolean  @default(true)
  creditCardDue   Boolean  @default(true)
  partnerBooking  Boolean  @default(true)
  turnNudge       Boolean  @default(true)
  goalReached     Boolean  @default(true)
  scanReminder    Boolean  @default(true)
}

model BudgetAlertSent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  threshold   Int
  periodStart DateTime
  createdAt   DateTime @default(now())

  @@unique([userId, categoryId, threshold, periodStart])
}

model Category {
  id                   String                 @id @default(cuid())
  name                 String
  icon                 String
  type                 String
  budget               Float?
  transactions         Transaction[]
  recurringTransactions RecurringTransaction[]
  budgetAlertsSent     BudgetAlertSent[]
}

model Account {
  id           String        @id @default(cuid())
  name         String
  icon         String        @default("🏦")
  color        String        @default("#6366f1")
  type         String        @default("personal")
  dueDay       Int?
  ownerName    String?
  transactions Transaction[]
  createdAt    DateTime      @default(now())

  @@index([type])
}

model Provision {
  id              String   @id @default(cuid())
  name            String
  icon            String   @default("📅")
  totalAmount     Float
  frequencyMonths Int      @default(12)  // 1=monthly, 3=quarterly, 6=half-yearly, 12=yearly
  nextDueDate     String                 // YYYY-MM-DD
  createdAt       DateTime @default(now())
}

model Transaction {
  id          String               @id @default(cuid())
  date        DateTime
  amount      Float
  description String?
  photoPath   String?
  categoryId  String
  category    Category             @relation(fields: [categoryId], references: [id])
  userId      String
  user        User                 @relation(fields: [userId], references: [id])
  contributor String?
  accountId   String?
  account     Account?             @relation(fields: [accountId], references: [id])
  recurringId String?
  recurring   RecurringTransaction? @relation(fields: [recurringId], references: [id])
  sharedWith      String?
  sharedRatio     Float?
  note            String?
  receiptId       String?
  receiptMerchant String?
  createdAt   DateTime             @default(now())

  @@index([date])
  @@index([accountId, date])
  @@index([categoryId, date])
  @@index([userId, createdAt])
  @@index([recurringId, date])
}

model SavingsGoal {
  id           String   @id @default(cuid())
  name         String
  icon         String   @default("🎯")
  targetAmount Float
  savedAmount  Float    @default(0)
  createdAt    DateTime @default(now())
}

model RecurringTransaction {
  id           String        @id @default(cuid())
  name         String
  amount       Float
  categoryId   String
  category     Category      @relation(fields: [categoryId], references: [id])
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  dayOfMonth   Int           @default(1)
  active       Boolean       @default(true)
  transactions Transaction[]
  createdAt    DateTime      @default(now())
}
