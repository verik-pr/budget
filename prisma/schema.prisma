generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                   String                 @id @default(cuid())
  name                 String
  email                String                 @unique
  password             String
  color                String                 @default("#6366f1")
  createdAt            DateTime               @default(now())
  transactions         Transaction[]
  recurringTransactions RecurringTransaction[]
}

model Category {
  id                   String                 @id @default(cuid())
  name                 String
  icon                 String
  type                 String
  transactions         Transaction[]
  recurringTransactions RecurringTransaction[]
}

model Account {
  id           String        @id @default(cuid())
  name         String
  icon         String        @default("🏦")
  color        String        @default("#6366f1")
  type         String        @default("personal") // "personal" | "shared"
  transactions Transaction[]
  createdAt    DateTime      @default(now())
}

model Transaction {
  id          String               @id @default(cuid())
  date        DateTime
  amount      Float
  description String?
  photoPath   String?
  categoryId  String
  category    Category             @relation(fields: [categoryId], references: [id])
  userId      String
  user        User                 @relation(fields: [userId], references: [id])
  contributor String?              // null = userId, "eltern_erik" | "eltern_celine" = Eltern
  accountId   String?
  account     Account?             @relation(fields: [accountId], references: [id])
  recurringId String?
  recurring   RecurringTransaction? @relation(fields: [recurringId], references: [id])
  sharedWith  String?              // contributor value of the other person (e.g. "celine")
  sharedRatio Float?               // fraction the other person owes (0.5 = half, 1.0 = full)
  createdAt   DateTime             @default(now())
}

model SavingsGoal {
  id           String   @id @default(cuid())
  name         String
  icon         String   @default("🎯")
  targetAmount Float
  savedAmount  Float    @default(0)
  createdAt    DateTime @default(now())
}

model RecurringTransaction {
  id           String        @id @default(cuid())
  name         String
  amount       Float
  categoryId   String
  category     Category      @relation(fields: [categoryId], references: [id])
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  dayOfMonth   Int           @default(1)
  active       Boolean       @default(true)
  transactions Transaction[]
  createdAt    DateTime      @default(now())
}
